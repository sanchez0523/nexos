# ── Admin credentials ────────────────────────────────────────────────────────
# Dashboard login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                         # set by setup.sh

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                             # min 32 bytes, generated by setup.sh
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h                    # 7 days

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=                      # generated by setup.sh

# ── MQTT ─────────────────────────────────────────────────────────────────────
# Internal ingestion-worker credentials (generated by setup.sh)
MQTT_INGESTION_USER=ingestion-worker
MQTT_INGESTION_PASS=                    # generated by setup.sh

# Internal health-check user (generated by setup.sh)
MQTT_HEALTH_USER=nexos-health
MQTT_HEALTH_PASS=                       # generated by setup.sh

# ── Data retention ───────────────────────────────────────────────────────────
# How many days to keep metrics in TimescaleDB (default: 90)
DATA_RETENTION_DAYS=90

# ── Alerting ─────────────────────────────────────────────────────────────────
# Minimum seconds between repeated webhook calls for the same alert rule
ALERT_TIMEOUT_SECONDS=60
